---
import { getLangFromUrl } from '../i18n/languages';
import { t } from '../i18n/utils';

interface Props {
  title: string;
  date: string;
  excerpt: string;
  slug: string;
  image?: string;
}

const lang = getLangFromUrl(Astro.url);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const { title, date, excerpt, slug, image } = Astro.props;

const palettes = [
  { from: '#e8f5e9', to: '#c8e6c9', accent: '#66bb6a' },
  { from: '#fce4ec', to: '#f8bbd0', accent: '#ec407a' },
  { from: '#fff8e1', to: '#ffecb3', accent: '#ffa726' },
  { from: '#e8eaf6', to: '#c5cae9', accent: '#7986cb' },
  { from: '#fff3e0', to: '#ffe0b2', accent: '#ff8a65' },
  { from: '#f3e5f5', to: '#e1bee7', accent: '#ab47bc' },
  { from: '#e0f2f1', to: '#b2dfdb', accent: '#26a69a' },
  { from: '#fff9c4', to: '#fff176', accent: '#d4e157' },
];
const hash = slug.split('').reduce((h, c) => ((h << 5) - h + c.charCodeAt(0)) | 0, 0);
const palette = palettes[Math.abs(hash) % palettes.length];
const initial = title.charAt(0).toUpperCase();
---

<a
  href={`${base}/${lang}/column/${slug}/`}
  class="group block bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-all duration-300 border border-sage-100"
>
  <div class="aspect-[16/9] bg-sage-50 overflow-hidden">
    {image ? (
      <img src={image} alt={title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" decoding="async" />
    ) : (
      <div class="w-full h-full flex flex-col items-center justify-center" style={`background: linear-gradient(135deg, ${palette.from}, ${palette.to});`}>
        <span class="text-3xl font-bold mb-1 select-none" style={`color: ${palette.accent};`}>{initial}</span>
        <svg class="w-8 h-8 opacity-30" style={`color: ${palette.accent};`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
        </svg>
      </div>
    )}
  </div>
  <div class="p-5">
    <time class="text-xs text-text/40">{date}</time>
    <h3 class="text-base font-bold text-text group-hover:text-sage-600 transition-colors mt-1 mb-2">{title}</h3>
    <p class="text-sm text-text/60 line-clamp-2 leading-relaxed">{excerpt}</p>
    <span class="inline-block mt-3 text-sm text-sage-500 font-medium group-hover:text-sage-600">
      {t(lang, 'common.readmore')} →
    </span>
  </div>
</a>
