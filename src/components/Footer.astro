---
import { getLangFromUrl } from '../i18n/languages';
import { t } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<footer class="bg-sage-800 text-sage-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
      <!-- Brand -->
      <div>
        <h3 class="text-xl font-bold text-white mb-2">BOTANICAL GRACE 8</h3>
        <p class="text-sage-300 text-sm">{t(lang, 'site.subtitle')}</p>
      </div>

      <!-- Links -->
      <div>
        <h4 class="text-sm font-semibold text-sage-200 uppercase tracking-wider mb-4">
          {t(lang, 'nav.courses')}
        </h4>
        <ul class="space-y-2 text-sm">
          <li><a href={`${base}/${lang}/courses/`} class="text-sage-300 hover:text-white transition-colors">{t(lang, 'nav.courses')}</a></li>
          <li><a href={`${base}/${lang}/herbs/`} class="text-sage-300 hover:text-white transition-colors">{t(lang, 'nav.herbs')}</a></li>
          <li><a href={`${base}/${lang}/voice/`} class="text-sage-300 hover:text-white transition-colors">{t(lang, 'nav.voice')}</a></li>
          <li><a href={`${base}/${lang}/column/`} class="text-sage-300 hover:text-white transition-colors">{t(lang, 'nav.column')}</a></li>
          <li><a href="https://bg8s.theshop.jp/" target="_blank" rel="noopener noreferrer" class="text-sage-300 hover:text-white transition-colors">{t(lang, 'footer.shop')}</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-sm font-semibold text-sage-200 uppercase tracking-wider mb-4">
          {t(lang, 'nav.contact')}
        </h4>
        <div class="space-y-3 text-sm text-sage-300">
          <p>{t(lang, 'footer.address')}</p>
          <p>
            <a href="tel:070-1581-0168" class="hover:text-white transition-colors">
              TEL: {t(lang, 'footer.phone')}
            </a>
          </p>
          <a
            href={`${base}/${lang}/contact/`}
            class="inline-block mt-2 px-5 py-2 bg-gold-400 text-sage-900 font-medium rounded-lg hover:bg-gold-300 transition-colors text-sm"
          >
            {t(lang, 'nav.contact')}
          </a>
        </div>
      </div>
    </div>

    <div class="mt-10 pt-8 border-t border-sage-700 text-center text-sm text-sage-400">
      <p>{t(lang, 'footer.copyright')}</p>
    </div>
  </div>
</footer>
