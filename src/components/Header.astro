---
import { getLangFromUrl } from '../i18n/languages';
import { t } from '../i18n/utils';
import LanguageToggle from './LanguageToggle.astro';

const lang = getLangFromUrl(Astro.url);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const navItems = [
  { href: `${base}/${lang}/`, label: t(lang, 'nav.home') },
  { href: `${base}/${lang}/courses/`, label: t(lang, 'nav.courses') },
  { href: `${base}/${lang}/herbs/`, label: t(lang, 'nav.herbs') },
  { href: `${base}/${lang}/voice/`, label: t(lang, 'nav.voice') },
  { href: `${base}/${lang}/column/`, label: t(lang, 'nav.column') },
  { href: `${base}/${lang}/teacher/`, label: t(lang, 'nav.teacher') },
  { href: `${base}/${lang}/for-corporations/`, label: t(lang, 'nav.corporate') },
  { href: `${base}/${lang}/contact/`, label: t(lang, 'nav.contact') },
];
---

<header class="sticky top-0 z-50 bg-cream/95 backdrop-blur-sm border-b border-sage-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-20">
      <!-- Logo -->
      <a href={`${base}/${lang}/`} class="flex items-center gap-2 shrink-0">
        <span class="text-xl lg:text-2xl font-bold text-sage-700 tracking-wide">BOTANICAL GRACE 8</span>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-1">
        {navItems.slice(1).map((item) => (
          <a
            href={item.href}
            class="px-3 py-2 text-sm font-medium text-text/80 hover:text-sage-600 hover:bg-sage-50 rounded-lg transition-colors"
          >
            {item.label}
          </a>
        ))}
        <div class="ml-2">
          <LanguageToggle />
        </div>
      </nav>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 text-text/70 hover:text-sage-600 rounded-lg"
        aria-label="Menu"
        aria-expanded="false"
      >
        <svg id="menu-icon" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="close-icon" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Nav -->
  <nav id="mobile-menu" class="hidden lg:hidden border-t border-sage-200 bg-cream">
    <div class="max-w-7xl mx-auto px-4 py-4 space-y-1">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="block px-4 py-3 text-base font-medium text-text/80 hover:text-sage-600 hover:bg-sage-50 rounded-lg transition-colors"
        >
          {item.label}
        </a>
      ))}
      <div class="pt-2 px-4">
        <LanguageToggle />
      </div>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    menuIcon?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
