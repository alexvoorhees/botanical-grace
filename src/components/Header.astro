---
import { getLangFromUrl } from '../i18n/languages';
import { t } from '../i18n/utils';
import LanguageToggle from './LanguageToggle.astro';

const lang = getLangFromUrl(Astro.url);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const courseGroups = {
  ja: {
    JAMHA: [
      { label: 'ハーバルセラピスト', slug: 'therapist' },
      { label: 'メディカルハーブコーディネーター', slug: 'medicalherb' },
      { label: 'ハーブ＆ライフコーディネーター', slug: 'herblife' },
    ],
    AEAJ: [
      { label: 'アロマテラピーアドバイザー', slug: 'aromatherapy' },
    ],
    other: [
      { label: 'フィトケミカル植物療法', slug: 'phytochemicals' },
      { label: '野菜のスープ・スムージー', slug: 'soup' },
    ],
  },
  en: {
    JAMHA: [
      { label: 'Herbal Therapist', slug: 'therapist' },
      { label: 'Medical Herb Coordinator', slug: 'medicalherb' },
      { label: 'Herb & Life Coordinator', slug: 'herblife' },
    ],
    AEAJ: [
      { label: 'Aromatherapy Advisor', slug: 'aromatherapy' },
    ],
    other: [
      { label: 'Phytochemical Plant Therapy', slug: 'phytochemicals' },
      { label: 'Soup & Smoothie Course', slug: 'soup' },
    ],
  },
};

const groups = courseGroups[lang] || courseGroups.en;

const navItems = [
  { href: `${base}/${lang}/herbs/`, label: t(lang, 'nav.herbs') },
  { href: `${base}/${lang}/voice/`, label: t(lang, 'nav.voice') },
  { href: `${base}/${lang}/column/`, label: t(lang, 'nav.column') },
  { href: `${base}/${lang}/teacher/`, label: t(lang, 'nav.teacher') },
  { href: `${base}/${lang}/for-corporations/`, label: t(lang, 'nav.corporate') },
  { href: `${base}/${lang}/contact/`, label: t(lang, 'nav.contact') },
];
---

<header class="sticky top-0 z-50 bg-cream/95 backdrop-blur-sm border-b border-sage-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-20">
      <!-- Logo -->
      <a href={`${base}/${lang}/`} class="flex items-center shrink-0 mr-4 lg:mr-6">
        <img src={`${base}/images/brand/logo_b.png`} alt="BOTANICAL GRACE 8" class="h-10 lg:h-12 w-auto" />
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-0.5">
        <!-- Courses Dropdown -->
        <div class="relative group" id="courses-dropdown">
          <button
            class="inline-flex items-center gap-1 px-2 py-2 text-sm font-medium text-text/80 hover:text-sage-600 hover:bg-sage-50 rounded-lg transition-colors whitespace-nowrap"
            aria-expanded="false"
            aria-haspopup="true"
          >
            {t(lang, 'nav.courses')}
            <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>

          <!-- Dropdown Panel -->
          <div class="absolute left-0 top-full pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
            <div class="bg-white rounded-xl shadow-lg border border-sage-100 p-4 min-w-[280px]">
              <a
                href={`${base}/${lang}/courses/`}
                class="block px-3 py-2 text-sm font-semibold text-sage-700 hover:bg-sage-50 rounded-lg mb-1"
              >
                {lang === 'ja' ? '講座一覧を見る' : 'View All Courses'} &rarr;
              </a>
              <div class="border-t border-sage-100 my-2"></div>

              <!-- JAMHA -->
              <p class="px-3 py-1 text-xs font-bold text-sage-500 uppercase tracking-wider">JAMHA</p>
              {groups.JAMHA.map((c) => (
                <a
                  href={`${base}/${lang}/courses/${c.slug}/`}
                  class="block px-3 py-1.5 text-sm text-text/70 hover:text-sage-600 hover:bg-sage-50 rounded-lg"
                >
                  {c.label}
                </a>
              ))}

              <!-- AEAJ -->
              <p class="px-3 py-1 mt-2 text-xs font-bold text-sage-500 uppercase tracking-wider">AEAJ</p>
              {groups.AEAJ.map((c) => (
                <a
                  href={`${base}/${lang}/courses/${c.slug}/`}
                  class="block px-3 py-1.5 text-sm text-text/70 hover:text-sage-600 hover:bg-sage-50 rounded-lg"
                >
                  {c.label}
                </a>
              ))}

              <!-- Other -->
              <p class="px-3 py-1 mt-2 text-xs font-bold text-sage-500 uppercase tracking-wider">
                {lang === 'ja' ? 'その他' : 'Other'}
              </p>
              {groups.other.map((c) => (
                <a
                  href={`${base}/${lang}/courses/${c.slug}/`}
                  class="block px-3 py-1.5 text-sm text-text/70 hover:text-sage-600 hover:bg-sage-50 rounded-lg"
                >
                  {c.label}
                </a>
              ))}
            </div>
          </div>
        </div>

        {navItems.map((item) => (
          <a
            href={item.href}
            class="px-2 py-2 text-sm font-medium text-text/80 hover:text-sage-600 hover:bg-sage-50 rounded-lg transition-colors whitespace-nowrap"
          >
            {item.label}
          </a>
        ))}
        <div class="ml-2">
          <LanguageToggle />
        </div>
      </nav>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 text-text/70 hover:text-sage-600 rounded-lg"
        aria-label="Menu"
        aria-expanded="false"
      >
        <svg id="menu-icon" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="close-icon" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Nav -->
  <nav id="mobile-menu" class="hidden lg:hidden border-t border-sage-200 bg-cream">
    <div class="max-w-7xl mx-auto px-4 py-4 space-y-1">
      <a
        href={`${base}/${lang}/`}
        class="block px-4 py-3 text-base font-medium text-text/80 hover:text-sage-600 hover:bg-sage-50 rounded-lg transition-colors"
      >
        {t(lang, 'nav.home')}
      </a>

      <!-- Mobile Courses Accordion -->
      <div>
        <button
          id="mobile-courses-btn"
          class="w-full flex items-center justify-between px-4 py-3 text-base font-medium text-text/80 hover:text-sage-600 hover:bg-sage-50 rounded-lg transition-colors"
          aria-expanded="false"
        >
          {t(lang, 'nav.courses')}
          <svg id="mobile-courses-chevron" class="w-5 h-5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div id="mobile-courses-panel" class="hidden pl-4 space-y-0.5">
          <a
            href={`${base}/${lang}/courses/`}
            class="block px-4 py-2 text-sm font-semibold text-sage-600 hover:bg-sage-50 rounded-lg"
          >
            {lang === 'ja' ? '講座一覧' : 'All Courses'}
          </a>
          <p class="px-4 pt-2 pb-1 text-xs font-bold text-sage-400 uppercase tracking-wider">JAMHA</p>
          {groups.JAMHA.map((c) => (
            <a
              href={`${base}/${lang}/courses/${c.slug}/`}
              class="block px-4 py-2 text-sm text-text/70 hover:text-sage-600 hover:bg-sage-50 rounded-lg"
            >
              {c.label}
            </a>
          ))}
          <p class="px-4 pt-2 pb-1 text-xs font-bold text-sage-400 uppercase tracking-wider">AEAJ</p>
          {groups.AEAJ.map((c) => (
            <a
              href={`${base}/${lang}/courses/${c.slug}/`}
              class="block px-4 py-2 text-sm text-text/70 hover:text-sage-600 hover:bg-sage-50 rounded-lg"
            >
              {c.label}
            </a>
          ))}
          <p class="px-4 pt-2 pb-1 text-xs font-bold text-sage-400 uppercase tracking-wider">
            {lang === 'ja' ? 'その他' : 'Other'}
          </p>
          {groups.other.map((c) => (
            <a
              href={`${base}/${lang}/courses/${c.slug}/`}
              class="block px-4 py-2 text-sm text-text/70 hover:text-sage-600 hover:bg-sage-50 rounded-lg"
            >
              {c.label}
            </a>
          ))}
        </div>
      </div>

      {navItems.map((item) => (
        <a
          href={item.href}
          class="block px-4 py-3 text-base font-medium text-text/80 hover:text-sage-600 hover:bg-sage-50 rounded-lg transition-colors"
        >
          {item.label}
        </a>
      ))}
      <div class="pt-2 px-4">
        <LanguageToggle />
      </div>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    menuIcon?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(!isOpen));
  });

  // Mobile courses accordion
  const coursesBtn = document.getElementById('mobile-courses-btn');
  const coursesPanel = document.getElementById('mobile-courses-panel');
  const coursesChevron = document.getElementById('mobile-courses-chevron');

  coursesBtn?.addEventListener('click', () => {
    const isOpen = !coursesPanel?.classList.contains('hidden');
    coursesPanel?.classList.toggle('hidden');
    coursesChevron?.classList.toggle('rotate-180');
    coursesBtn.setAttribute('aria-expanded', String(!isOpen));
  });

  // Desktop dropdown keyboard navigation
  const dropdown = document.getElementById('courses-dropdown');
  if (dropdown) {
    const trigger = dropdown.querySelector('button');
    const links = dropdown.querySelectorAll<HTMLAnchorElement>('a');

    trigger?.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowDown' || e.key === 'Enter') {
        e.preventDefault();
        dropdown.querySelector<HTMLDivElement>('.absolute')?.classList.add('!opacity-100', '!visible');
        trigger.setAttribute('aria-expanded', 'true');
        links[0]?.focus();
      }
    });

    links.forEach((link, i) => {
      link.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowDown') {
          e.preventDefault();
          (links[i + 1] || links[0])?.focus();
        } else if (e.key === 'ArrowUp') {
          e.preventDefault();
          if (i === 0) {
            trigger?.focus();
            dropdown.querySelector<HTMLDivElement>('.absolute')?.classList.remove('!opacity-100', '!visible');
            trigger?.setAttribute('aria-expanded', 'false');
          } else {
            links[i - 1]?.focus();
          }
        } else if (e.key === 'Escape') {
          e.preventDefault();
          dropdown.querySelector<HTMLDivElement>('.absolute')?.classList.remove('!opacity-100', '!visible');
          trigger?.setAttribute('aria-expanded', 'false');
          trigger?.focus();
        } else if (e.key === 'Home') {
          e.preventDefault();
          links[0]?.focus();
        } else if (e.key === 'End') {
          e.preventDefault();
          links[links.length - 1]?.focus();
        }
      });
    });

    // Close dropdown when focus leaves
    dropdown.addEventListener('focusout', (e) => {
      if (!dropdown.contains((e as FocusEvent).relatedTarget as Node)) {
        dropdown.querySelector<HTMLDivElement>('.absolute')?.classList.remove('!opacity-100', '!visible');
        trigger?.setAttribute('aria-expanded', 'false');
      }
    });
  }
</script>
