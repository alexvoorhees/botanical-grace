---
import { getLangFromUrl } from '../i18n/languages';

interface Props {
  title: string;
  nameJa: string;
  nameEn: string;
  scientificName: string;
  actions: string[];
  slug: string;
  image?: string;
}

const lang = getLangFromUrl(Astro.url);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const { title, nameJa, nameEn, scientificName, actions, slug, image } = Astro.props;
---

<a
  href={`${base}/${lang}/herbs/${slug}/`}
  class="group block bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-all duration-300 border border-sage-100"
>
  <div class="aspect-square bg-sage-50 overflow-hidden">
    {image ? (
      <img src={image} alt={title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
    ) : (
      <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-sage-50 to-sage-100">
        <span class="text-5xl">🌱</span>
      </div>
    )}
  </div>
  <div class="p-4">
    <h3 class="font-bold text-text group-hover:text-sage-600 transition-colors">{title}</h3>
    <p class="text-xs text-text/40 italic mt-0.5">{scientificName}</p>
    <div class="flex flex-wrap gap-1 mt-2">
      {actions.slice(0, 3).map((action) => (
        <span class="text-xs bg-sage-50 text-sage-600 px-2 py-0.5 rounded-full">{action}</span>
      ))}
    </div>
  </div>
</a>
