---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getLangFromUrl, getLocalizedUrl } from '../i18n/languages';
import { t } from '../i18n/utils';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const lang = getLangFromUrl(Astro.url);
const { title, description, ogImage } = Astro.props;

const siteTitle = t(lang, 'site.title');
const pageTitle = title ? `${title} | ${siteTitle}` : siteTitle;
const pageDescription = description || t(lang, 'site.description');

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const siteUrl = import.meta.env.SITE || 'https://alexvoorhees.github.io';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
const ogImageUrl = new URL(ogImage || `${base}/images/hero/slide1.jpg`, siteUrl).href;

const altLang = lang === 'ja' ? 'en' : 'ja';
const altUrl = new URL(getLocalizedUrl(Astro.url, altLang as 'ja' | 'en'), siteUrl).href;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDescription} />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}/favicon.svg`} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang={lang} href={canonicalUrl} />
    <link rel="alternate" hreflang={altLang} href={altUrl} />
    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteTitle} />
    <meta property="og:locale" content={lang === 'ja' ? 'ja_JP' : 'en_US'} />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "EducationalOrganization",
      "name": "BOTANICAL GRACE 8",
      "url": siteUrl + base,
      "logo": siteUrl + base + "/images/brand/logo_b.png",
      "description": pageDescription,
      "telephone": "070-1581-0168",
      "email": "info@botanicalgrace8.com",
      "address": {
        "@type": "PostalAddress",
        "addressCountry": "JP"
      },
      "sameAs": [],
      "openingHours": "Mo-Su 11:00-20:00",
      "inLanguage": [lang === 'ja' ? 'ja' : 'en']
    })} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Sans+JP:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <title>{pageTitle}</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <script data-goatcounter="https://botanicalgrace.goatcounter.com/count"
            async src="//gc.zgo.at/count.js"></script>
  </body>
</html>
