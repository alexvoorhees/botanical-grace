---
// Standalone admin page — no BaseLayout, no i18n
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex, nofollow">
  <title>Kimiko 管理画面 — ボタニカルグレイス8</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Sans+JP:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href={`${base}/admin/style.css`}>
</head>
<body>
  <!-- Login Screen -->
  <div id="login-screen">
    <div class="login-card">
      <h1>Kimiko 管理画面</h1>
      <p class="login-subtitle">ボタニカルグレイス8</p>
      <form id="login-form">
        <div class="login-field">
          <label for="login-email">メールアドレス</label>
          <input type="email" id="login-email" autocomplete="email" required>
        </div>
        <div class="login-field">
          <label for="login-password">パスワード</label>
          <div class="password-wrapper">
            <input type="password" id="login-password" autocomplete="current-password" required>
            <button type="button" class="password-toggle" id="password-toggle" aria-label="パスワードを表示">
              <svg class="icon-eye-open" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8S1 12 1 12z"/><circle cx="12" cy="12" r="3"/></svg>
              <svg class="icon-eye-closed" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="display:none"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><path d="M14.12 14.12a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
            </button>
          </div>
        </div>
        <div class="login-error" id="login-error"></div>
        <button type="submit" class="login-btn" id="login-btn">ログイン</button>
      </form>
    </div>
  </div>

  <!-- Admin App (hidden until login) -->
  <div id="app">
    <aside id="sidebar">
      <div class="sidebar-header">
        <h1>Kimiko 管理画面</h1>
        <p>ボタニカルグレイス8</p>
      </div>
      <nav>
        <a href="#articles" class="nav-item" data-collection="articles">
          <span class="nav-icon"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg></span>
          <span class="nav-label">記事</span>
          <span class="nav-count" id="count-articles">—</span>
        </a>
        <a href="#herbs" class="nav-item" data-collection="herbs">
          <span class="nav-icon"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 21c3-3 6-6 6-12"/><path d="M12 9c0-3 2.5-6 6-7.5C18.5 5 16 9 12 9z"/><path d="M12 9c0-3-2.5-6-6-7.5C5.5 5 8 9 12 9z"/></svg></span>
          <span class="nav-label">ハーブ</span>
          <span class="nav-count" id="count-herbs">—</span>
        </a>
        <a href="#courses" class="nav-item" data-collection="courses">
          <span class="nav-icon"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/><line x1="8" y1="7" x2="16" y2="7"/><line x1="8" y1="11" x2="13" y2="11"/></svg></span>
          <span class="nav-label">コース</span>
          <span class="nav-count" id="count-courses">—</span>
        </a>
      </nav>
      <div class="sidebar-footer">
        <div class="lang-filter">
          <label>コンテンツ言語:</label>
          <select id="lang-filter">
            <option value="all">すべて</option>
            <option value="en">英語</option>
            <option value="ja">日本語</option>
          </select>
        </div>
        <button class="btn-ui-lang" id="btn-ui-lang">English</button>
        <button class="btn-logout" id="btn-logout">ログアウト</button>
      </div>
    </aside>
    <main id="content">
      <div class="welcome-screen">
        <h2>Kimiko 管理画面へようこそ</h2>
        <p>サイドバーからコレクションを選んでください。</p>
      </div>
    </main>
  </div>

  <div id="toast-container"></div>

  <script type="module" src={`${base}/admin/app.mjs`}></script>
</body>
</html>
