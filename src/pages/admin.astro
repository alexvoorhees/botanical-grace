---
// Standalone admin page — no BaseLayout, no i18n
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex, nofollow">
  <title>Kimiko Admin — Botanical Grace 8</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Sans+JP:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href={`${base}/admin/style.css`}>
</head>
<body>
  <!-- Login Screen -->
  <div id="login-screen">
    <div class="login-card">
      <h1>Kimiko Admin</h1>
      <p class="login-subtitle">Botanical Grace 8</p>
      <form id="login-form">
        <div class="login-field">
          <label for="login-email">Email</label>
          <input type="email" id="login-email" autocomplete="email" required>
        </div>
        <div class="login-field">
          <label for="login-password">Password</label>
          <input type="password" id="login-password" autocomplete="current-password" required>
        </div>
        <div class="login-error" id="login-error"></div>
        <button type="submit" class="login-btn" id="login-btn">Log In</button>
      </form>
    </div>
  </div>

  <!-- Admin App (hidden until login) -->
  <div id="app">
    <aside id="sidebar">
      <div class="sidebar-header">
        <h1>Kimiko Admin</h1>
        <p>Botanical Grace 8</p>
      </div>
      <nav>
        <a href="#articles" class="nav-item" data-collection="articles">
          <span class="nav-icon">📝</span>
          <span class="nav-label">Articles</span>
          <span class="nav-count" id="count-articles">—</span>
        </a>
        <a href="#herbs" class="nav-item" data-collection="herbs">
          <span class="nav-icon">🌿</span>
          <span class="nav-label">Herbs</span>
          <span class="nav-count" id="count-herbs">—</span>
        </a>
        <a href="#courses" class="nav-item" data-collection="courses">
          <span class="nav-icon">📚</span>
          <span class="nav-label">Courses</span>
          <span class="nav-count" id="count-courses">—</span>
        </a>
      </nav>
      <div class="sidebar-footer">
        <div class="lang-filter">
          <label>Language filter:</label>
          <select id="lang-filter">
            <option value="all">All</option>
            <option value="en">English</option>
            <option value="ja">Japanese</option>
          </select>
        </div>
        <button class="btn-logout" id="btn-logout">Log Out</button>
      </div>
    </aside>
    <main id="content">
      <div class="welcome-screen">
        <h2>Welcome to Kimiko Admin</h2>
        <p>Select a collection from the sidebar to get started.</p>
      </div>
    </main>
  </div>

  <div id="toast-container"></div>

  <script type="module" src={`${base}/admin/app.mjs`}></script>
</body>
</html>
