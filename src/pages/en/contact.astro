---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from '../../i18n/utils';

const lang = 'en';
---

<BaseLayout title={t(lang, 'contact.title')}>
  <section class="py-16 lg:py-24">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h1 class="text-3xl lg:text-4xl font-bold text-text mb-3">{t(lang, 'contact.title')}</h1>
        <p class="text-text/60">{t(lang, 'contact.subtitle')}</p>
      </div>

      <!-- Phone & Email -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-10">
        <div class="bg-sage-50 rounded-2xl p-6 text-center">
          <p class="text-sm text-text/60 mb-2">{t(lang, 'contact.phone_label')}</p>
          <a href="tel:070-1581-0168" class="text-xl font-bold text-sage-700 hover:text-sage-600">
            {t(lang, 'footer.phone')}
          </a>
        </div>
        <div class="bg-sage-50 rounded-2xl p-6 text-center">
          <p class="text-sm text-text/60 mb-2">Email</p>
          <a href="mailto:info@botanicalgrace8.com" class="text-base font-bold text-sage-700 hover:text-sage-600">
            info@botanicalgrace8.com
          </a>
        </div>
      </div>

      <form
        action="https://formspree.io/f/placeholder"
        method="POST"
        class="bg-white rounded-2xl shadow-sm border border-sage-100 p-6 lg:p-10 space-y-6"
      >
        <div>
          <label for="name" class="block text-sm font-medium text-text mb-2">{t(lang, 'contact.name')}</label>
          <input
            type="text" id="name" name="name" required
            class="w-full px-4 py-3 rounded-xl border border-sage-200 focus:ring-2 focus:ring-sage-400 focus:border-sage-400 outline-none transition-colors bg-cream"
          />
        </div>
        <div>
          <label for="email" class="block text-sm font-medium text-text mb-2">{t(lang, 'contact.email')}</label>
          <input
            type="email" id="email" name="email" required
            class="w-full px-4 py-3 rounded-xl border border-sage-200 focus:ring-2 focus:ring-sage-400 focus:border-sage-400 outline-none transition-colors bg-cream"
          />
        </div>
        <div>
          <label for="phone" class="block text-sm font-medium text-text mb-2">{t(lang, 'contact.phone')}</label>
          <input
            type="tel" id="phone" name="phone"
            class="w-full px-4 py-3 rounded-xl border border-sage-200 focus:ring-2 focus:ring-sage-400 focus:border-sage-400 outline-none transition-colors bg-cream"
          />
        </div>
        <div>
          <label for="course" class="block text-sm font-medium text-text mb-2">{t(lang, 'contact.course')}</label>
          <select
            id="course" name="course"
            class="w-full px-4 py-3 rounded-xl border border-sage-200 focus:ring-2 focus:ring-sage-400 focus:border-sage-400 outline-none transition-colors bg-cream"
          >
            <option value="">Please select</option>
            <option value="herbal-therapist">JAMHA Herbal Therapist</option>
            <option value="medical-herb">Medical Herb Coordinator</option>
            <option value="herb-life">Herb & Life Coordinator</option>
            <option value="aromatherapy">AEAJ Aromatherapy Advisor</option>
            <option value="phytochemicals">Phytochemical Plant Therapy</option>
            <option value="soup">Vegetable Soup & Smoothie</option>
            <option value="other">Other</option>
          </select>
        </div>
        <div>
          <label for="message" class="block text-sm font-medium text-text mb-2">{t(lang, 'contact.message')}</label>
          <textarea
            id="message" name="message" rows="5" required
            class="w-full px-4 py-3 rounded-xl border border-sage-200 focus:ring-2 focus:ring-sage-400 focus:border-sage-400 outline-none transition-colors bg-cream resize-y"
          ></textarea>
        </div>
        <input type="text" name="_gotcha" class="hidden" />
        <button
          type="submit"
          class="w-full py-4 bg-gold-400 text-sage-900 font-semibold rounded-xl hover:bg-gold-300 transition-colors text-lg"
        >
          {t(lang, 'contact.submit')}
        </button>
      </form>

      <div class="mt-10 text-center text-sm text-text/50">
        <p>{t(lang, 'footer.address')}</p>
      </div>
    </div>
  </section>
</BaseLayout>
