---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from '../../i18n/utils';

const lang = 'en';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title={t(lang, 'corporate.title')}>
  <section class="py-16 lg:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h1 class="text-3xl lg:text-4xl font-bold text-text mb-3">{t(lang, 'corporate.title')}</h1>
        <p class="text-text/60">{t(lang, 'corporate.subtitle')}</p>
      </div>

      <div class="space-y-8">
        <div class="bg-white rounded-2xl shadow-sm border border-sage-100 p-6 lg:p-10">
          <h2 class="text-xl font-bold text-text mb-4">Corporate & Group Training Programs</h2>
          <p class="text-text/70 leading-relaxed mb-6">
            BOTANICAL GRACE 8 offers group training programs for corporations and organizations.
            As part of employee wellness initiatives, we provide opportunities to learn about herbs and aromatherapy.
          </p>

          <div class="bg-sage-50 rounded-xl p-6 mb-6">
            <h3 class="font-bold text-text mb-3">Group Discount</h3>
            <p class="text-text/70">For groups of 3 or more, the special rate is <strong class="text-sage-700">¥88,800</strong> per person (tax included).</p>
          </div>

          <h3 class="font-bold text-text mb-3">Program Contents</h3>
          <ul class="space-y-2 text-text/70">
            <li class="flex items-start gap-2">
              <span class="text-sage-500 mt-1">•</span>
              <span>Fundamentals of Herbs & Aromatherapy</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-sage-500 mt-1">•</span>
              <span>Stress Management & Relaxation</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-sage-500 mt-1">•</span>
              <span>Self-Care & Wellness</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-sage-500 mt-1">•</span>
              <span>Certification-Oriented Programs</span>
            </li>
          </ul>
        </div>

        <div class="text-center">
          <a
            href={`${base}/${lang}/contact/`}
            class="inline-flex items-center gap-2 px-8 py-4 bg-gold-400 text-sage-900 font-semibold rounded-xl hover:bg-gold-300 transition-colors text-lg"
          >
            {t(lang, 'nav.contact')}
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
