---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CourseCard from '../../components/CourseCard.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { t } from '../../i18n/utils';

const lang = 'en';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const allCourses = await getCollection('courses');
const courses = allCourses
  .filter((c) => c.data.lang === lang)
  .sort((a, b) => a.data.order - b.data.order);

const allArticles = await getCollection('articles');
const articles = allArticles.filter((a) => a.data.lang === lang).slice(0, 3);

const heroSlides = [
  {
    image: `${base}/images/hero/slide1.jpg`,
    heading: 'Wellness Through the Power of Herbs',
    sub: 'Professional herb & aromatherapy certifications at a JAMHA/AEAJ accredited school',
  },
  {
    image: `${base}/images/hero/slide2.jpg`,
    heading: 'High Pass Rates, Proven Results',
    sub: 'One-on-one instruction with thorough exam preparation',
  },
  {
    image: `${base}/images/hero/slide3.jpg`,
    heading: '2 Minutes from Tameike-Sanno Station',
    sub: 'Available in-person or online via Zoom. Parents with children welcome',
  },
];

const announcements = [
  { text: 'Free consultation sessions available. Contact us to learn more about our courses.', highlight: true },
  { text: 'Group discount (3+): Save ¥30,000 per person on the Herbal Therapist course!', highlight: false },
  { text: 'Installment payment plans available for the Herbal Therapist course.', highlight: false },
];
---

<BaseLayout>
  <!-- Hero Carousel -->
  <section class="relative overflow-hidden" id="hero-carousel">
    <div class="relative h-[480px] sm:h-[520px] lg:h-[560px]">
      {heroSlides.map((slide, i) => (
        <div
          class:list={[
            'hero-slide absolute inset-0 transition-opacity duration-700',
            i === 0 ? 'opacity-100' : 'opacity-0',
          ]}
          data-slide={i}
        >
          <img
            src={slide.image}
            alt=""
            class="absolute inset-0 w-full h-full object-cover"
            loading={i === 0 ? 'eager' : 'lazy'}
          />
          <div class="absolute inset-0 bg-gradient-to-b from-sage-900/60 via-sage-900/50 to-sage-900/70"></div>
          <div class="relative h-full flex items-center">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center w-full">
              <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-4 tracking-tight leading-tight drop-shadow-lg">
                {slide.heading}
              </h1>
              <p class="text-lg sm:text-xl text-white/90 max-w-2xl mx-auto mb-8 drop-shadow-md">
                {slide.sub}
              </p>
              <div class="flex flex-col sm:flex-row gap-4 justify-center">
                <a
                  href={`${base}/${lang}/courses/`}
                  class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-white text-sage-700 font-semibold rounded-xl hover:bg-sage-50 transition-colors text-lg shadow-lg"
                >
                  {t(lang, 'hero.cta')}
                </a>
                <a
                  href={`${base}/${lang}/contact/`}
                  class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-white/15 text-white font-semibold rounded-xl border-2 border-white/30 hover:bg-white/25 transition-colors text-lg backdrop-blur-sm"
                >
                  {t(lang, 'hero.contact')}
                </a>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Carousel Indicators -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex gap-2 z-10">
      {heroSlides.map((_, i) => (
        <button
          class:list={[
            'carousel-dot w-3 h-3 rounded-full transition-all duration-300',
            i === 0 ? 'bg-white w-8' : 'bg-white/50',
          ]}
          data-dot={i}
          aria-label={`Slide ${i + 1}`}
        />
      ))}
    </div>
  </section>

  <!-- Announcements Bar -->
  <section class="bg-gold-50 border-y border-gold-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <div class="flex items-start gap-3">
        <span class="shrink-0 text-gold-600 font-bold text-sm bg-gold-200 px-3 py-1 rounded-full mt-0.5">
          News
        </span>
        <ul class="space-y-1.5 text-sm text-text/80">
          {announcements.map((a) => (
            <li class="flex items-start gap-2">
              <span class:list={['shrink-0 mt-1.5 w-1.5 h-1.5 rounded-full', a.highlight ? 'bg-gold-500' : 'bg-sage-300']} />
              {a.highlight ? <strong>{a.text}</strong> : <span>{a.text}</span>}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Classroom Features -->
  <section class="py-16 lg:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-text mb-3">Why Choose Us</h2>
        <p class="text-text/60">What makes BOTANICAL GRACE 8 special</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-6">
        <div class="text-center p-5 rounded-2xl bg-sage-50/50 border border-sage-100">
          <div class="w-14 h-14 mx-auto mb-3 rounded-2xl bg-sage-100 flex items-center justify-center">
            <svg class="w-7 h-7 text-sage-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5" />
            </svg>
          </div>
          <h3 class="font-bold text-text text-sm mb-1">JAMHA & AEAJ Accredited</h3>
          <p class="text-xs text-text/60">Officially certified classroom</p>
        </div>
        <div class="text-center p-5 rounded-2xl bg-sage-50/50 border border-sage-100">
          <div class="w-14 h-14 mx-auto mb-3 rounded-2xl bg-sage-100 flex items-center justify-center">
            <svg class="w-7 h-7 text-sage-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
            </svg>
          </div>
          <h3 class="font-bold text-text text-sm mb-1">2 Min from Station</h3>
          <p class="text-xs text-text/60">Central Akasaka location</p>
        </div>
        <div class="text-center p-5 rounded-2xl bg-sage-50/50 border border-sage-100">
          <div class="w-14 h-14 mx-auto mb-3 rounded-2xl bg-sage-100 flex items-center justify-center">
            <svg class="w-7 h-7 text-sage-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
            </svg>
          </div>
          <h3 class="font-bold text-text text-sm mb-1">Flexible Scheduling</h3>
          <p class="text-xs text-text/60">Choose your own lesson days</p>
        </div>
        <div class="text-center p-5 rounded-2xl bg-sage-50/50 border border-sage-100">
          <div class="w-14 h-14 mx-auto mb-3 rounded-2xl bg-sage-100 flex items-center justify-center">
            <svg class="w-7 h-7 text-sage-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
            </svg>
          </div>
          <h3 class="font-bold text-text text-sm mb-1">One-on-One Lessons</h3>
          <p class="text-xs text-text/60">Online & children welcome</p>
        </div>
        <div class="text-center p-5 rounded-2xl bg-sage-50/50 border border-sage-100">
          <div class="w-14 h-14 mx-auto mb-3 rounded-2xl bg-sage-100 flex items-center justify-center">
            <svg class="w-7 h-7 text-sage-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z" />
            </svg>
          </div>
          <h3 class="font-bold text-text text-sm mb-1">Free Exam Prep</h3>
          <p class="text-xs text-text/60">Support until you pass</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Courses Section -->
  <section class="py-16 lg:py-24 bg-cream">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-text mb-3">{t(lang, 'courses.title')}</h2>
        <p class="text-text/60">{t(lang, 'courses.subtitle')}</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        {courses.map((course) => (
          <CourseCard
            title={course.data.title}
            description={course.data.description}
            certification={course.data.certification}
            price={course.data.price}
            sessions={course.data.sessions}
            totalHours={course.data.totalHours}
            slug={course.data.slug}
            image={course.data.image}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Articles Preview -->
  {articles.length > 0 && (
    <section class="py-16 lg:py-24 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-text mb-3">{t(lang, 'column.title')}</h2>
          <p class="text-text/60">{t(lang, 'column.subtitle')}</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
          {articles.map((article) => (
            <ArticleCard
              title={article.data.title}
              date={article.data.date}
              excerpt={article.data.excerpt}
              slug={article.data.slug}
              image={article.data.image}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="py-16 lg:py-24 bg-sage-700 text-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold mb-4">Start Your Herbal Journey</h2>
      <p class="text-sage-200 mb-8 text-lg">Contact us for a free consultation or to learn more about our certification programs.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={`${base}/${lang}/contact/`}
          class="inline-flex items-center gap-2 px-8 py-4 bg-gold-400 text-sage-900 font-semibold rounded-xl hover:bg-gold-300 transition-colors text-lg"
        >
          {t(lang, 'nav.contact')}
        </a>
        <a
          href="tel:070-1581-0168"
          class="inline-flex items-center gap-2 px-8 py-4 bg-white/15 text-white font-semibold rounded-xl border-2 border-white/30 hover:bg-white/25 transition-colors text-lg"
        >
          TEL: 070-1581-0168
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const slides = document.querySelectorAll('.hero-slide');
  const dots = document.querySelectorAll('.carousel-dot');
  let current = 0;
  const total = slides.length;

  function goTo(index: number) {
    slides[current]?.classList.remove('opacity-100');
    slides[current]?.classList.add('opacity-0');
    dots[current]?.classList.remove('bg-white', 'w-8');
    dots[current]?.classList.add('bg-white/50');

    current = index;

    slides[current]?.classList.remove('opacity-0');
    slides[current]?.classList.add('opacity-100');
    dots[current]?.classList.remove('bg-white/50');
    dots[current]?.classList.add('bg-white', 'w-8');
  }

  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => goTo(i));
  });

  setInterval(() => {
    goTo((current + 1) % total);
  }, 5000);
</script>
