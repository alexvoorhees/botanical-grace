---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CourseCard from '../../components/CourseCard.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { t } from '../../i18n/utils';

const lang = 'en';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const allTestimonials = await getCollection('testimonials');
const testimonials = allTestimonials.filter((te) => te.data.lang === lang);

const iconMap: Record<string, string> = {
  'T.N.': `${base}/images/voice/icons/voice_icon1.png`,
  'K.T.': `${base}/images/voice/icons/voice_icon2.png`,
  'M.Y.': `${base}/images/voice/icons/voice_icon3.png`,
  'Y.S.': `${base}/images/voice/icons/voice_icon4.png`,
  'H.M.': `${base}/images/voice/icons/voice_icon5.png`,
  'M.K.': `${base}/images/voice/icons/voice_icon6.png`,
  'A.K.': `${base}/images/voice/icons/voice_icon7.png`,
  'M.T.': `${base}/images/voice/icons/voice_icon8.png`,
  'M.S.': `${base}/images/voice/icons/voice_icon1.png`,
};

const allCourses = await getCollection('courses');
const courses = allCourses
  .filter((c) => c.data.lang === lang)
  .sort((a, b) => a.data.order - b.data.order);

const allArticles = await getCollection('articles');
const articles = allArticles.filter((a) => a.data.lang === lang).slice(0, 6);

const heroSlides = [
  {
    image: `${base}/images/hero/slide1.jpg`,
    heading: 'Wellness Through the Power of Herbs',
    sub: 'Professional herb & aromatherapy certifications at a JAMHA/AEAJ accredited school',
  },
  {
    image: `${base}/images/hero/slide2.jpg`,
    heading: 'High Pass Rates, Proven Results',
    sub: 'One-on-one instruction with thorough exam preparation',
  },
  {
    image: `${base}/images/hero/slide3.jpg`,
    heading: '2 Minutes from Tameike-Sanno Station',
    sub: 'Available in-person or online via Zoom. Parents with children welcome',
  },
];

const announcements = [
  { text: 'Free consultation sessions available. Contact us to learn more about our courses.', highlight: true },
  { text: 'Group discount (3+): Save ¥30,000 per person on the Herbal Therapist course!', highlight: false },
  { text: 'Installment payment plans available for the Herbal Therapist course.', highlight: false },
];
---

<BaseLayout>
  <!-- Hero Carousel -->
  <section class="relative overflow-hidden" id="hero-carousel">
    <div class="relative h-[480px] sm:h-[520px] lg:h-[560px]">
      {heroSlides.map((slide, i) => (
        <div
          class:list={[
            'hero-slide absolute inset-0 transition-opacity duration-700',
            i === 0 ? 'opacity-100' : 'opacity-0',
          ]}
          data-slide={i}
        >
          <img
            src={slide.image}
            alt=""
            class="absolute inset-0 w-full h-full object-cover"
            loading={i === 0 ? 'eager' : 'lazy'}
          />
          <div class="absolute inset-0 bg-gradient-to-b from-sage-900/60 via-sage-900/50 to-sage-900/70"></div>
          <div class="relative h-full flex items-center">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center w-full">
              <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-4 tracking-tight leading-tight drop-shadow-lg">
                {slide.heading}
              </h1>
              <p class="text-lg sm:text-xl text-white/90 max-w-2xl mx-auto mb-8 drop-shadow-md">
                {slide.sub}
              </p>
              <div class="flex flex-col sm:flex-row gap-4 justify-center">
                <a
                  href={`${base}/${lang}/courses/`}
                  class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-white text-sage-700 font-semibold rounded-xl hover:bg-sage-50 transition-colors text-lg shadow-lg"
                >
                  {t(lang, 'hero.cta')}
                </a>
                <a
                  href={`${base}/${lang}/contact/`}
                  class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-white/15 text-white font-semibold rounded-xl border-2 border-white/30 hover:bg-white/25 transition-colors text-lg backdrop-blur-sm"
                >
                  {t(lang, 'hero.contact')}
                </a>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Carousel Indicators -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex gap-2 z-10">
      {heroSlides.map((_, i) => (
        <button
          class:list={[
            'carousel-dot w-3 h-3 rounded-full transition-all duration-300',
            i === 0 ? 'bg-white w-8' : 'bg-white/50',
          ]}
          data-dot={i}
          aria-label={`Slide ${i + 1}`}
        />
      ))}
    </div>
  </section>

  <!-- Announcements Bar -->
  <section class="bg-gold-50 border-y border-gold-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <div class="flex items-start gap-3">
        <span class="shrink-0 text-gold-600 font-bold text-sm bg-gold-200 px-3 py-1 rounded-full mt-0.5">
          News
        </span>
        <ul class="space-y-1.5 text-sm text-text/80 leading-relaxed">
          {announcements.map((a) => (
            <li class="flex items-start gap-2">
              <span class:list={['shrink-0 mt-1.5 w-1.5 h-1.5 rounded-full', a.highlight ? 'bg-gold-500' : 'bg-sage-300']} />
              {a.highlight ? <strong>{a.text}</strong> : <span>{a.text}</span>}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Welcome Intro -->
  <section class="py-16 lg:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl font-bold text-text mb-6 text-balance">Clear, Thorough Online<br />Herb Education</h2>
          <p class="text-text/70 leading-relaxed mb-4">
            Earn your herb certification from home and apply it to your career or daily life. For those aiming for Herbal Therapist certification, we provide full guidance and support toward passing the exam.
          </p>
          <ul class="space-y-2 text-text/70 mb-6">
            <li class="flex items-start gap-2">
              <span class="text-sage-500 mt-1">●</span>
              Complete beginners are welcome.
            </li>
            <li class="flex items-start gap-2">
              <span class="text-sage-500 mt-1">●</span>
              Available online and in-person.
            </li>
          </ul>
          <a
            href={`${base}/${lang}/courses/`}
            class="inline-flex items-center gap-2 px-6 py-3 bg-sage-600 text-white font-semibold rounded-xl hover:bg-sage-700 transition-colors"
          >
            View Courses
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
            </svg>
          </a>
        </div>
        <div class="relative">
          <img
            src={`${base}/images/hero/slide1.jpg`}
            alt="Herb classroom"
            class="rounded-2xl shadow-lg w-full object-cover aspect-[4/3]"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Philosophy -->
  <section class="py-16 lg:py-20 bg-cream">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl lg:text-3xl font-bold text-text mb-4 text-balance">Food as Medicine</h2>
      <p class="text-lg text-text/60 mb-6 leading-relaxed">Plant therapy is beneficial in both medical and beauty fields</p>
      <p class="text-text/70 leading-relaxed max-w-2xl mx-auto">
        The ancient Eastern wisdom that food and medicine share the same source continues to guide holistic health practices today. Phytochemicals and essential oil compounds found in plants support our well-being through immune enhancement, stress relief, beauty care, and more. At BOTANICAL GRACE 8, we combine this traditional wisdom with modern science in our teaching.
      </p>
    </div>
  </section>

  <!-- Classroom Features -->
  <section class="py-16 lg:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-text mb-3 text-balance">Why Choose Us</h2>
        <p class="text-text/60">What makes BOTANICAL GRACE 8 special</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-6">
        <div class="text-center p-5 rounded-2xl bg-sage-50/50 border border-sage-100">
          <div class="w-14 h-14 mx-auto mb-3 rounded-2xl bg-sage-100 flex items-center justify-center">
            <svg class="w-7 h-7 text-sage-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5" />
            </svg>
          </div>
          <h3 class="font-bold text-text text-sm mb-1">JAMHA & AEAJ Accredited</h3>
          <p class="text-xs text-text/60">Officially certified classroom</p>
        </div>
        <div class="text-center p-5 rounded-2xl bg-sage-50/50 border border-sage-100">
          <div class="w-14 h-14 mx-auto mb-3 rounded-2xl bg-sage-100 flex items-center justify-center">
            <svg class="w-7 h-7 text-sage-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
            </svg>
          </div>
          <h3 class="font-bold text-text text-sm mb-1">Steps from Shiodome Station</h3>
          <p class="text-xs text-text/60">Central Shiodome location</p>
        </div>
        <div class="text-center p-5 rounded-2xl bg-sage-50/50 border border-sage-100">
          <div class="w-14 h-14 mx-auto mb-3 rounded-2xl bg-sage-100 flex items-center justify-center">
            <svg class="w-7 h-7 text-sage-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
            </svg>
          </div>
          <h3 class="font-bold text-text text-sm mb-1">Flexible Scheduling</h3>
          <p class="text-xs text-text/60">Choose your own lesson days</p>
        </div>
        <div class="text-center p-5 rounded-2xl bg-sage-50/50 border border-sage-100">
          <div class="w-14 h-14 mx-auto mb-3 rounded-2xl bg-sage-100 flex items-center justify-center">
            <svg class="w-7 h-7 text-sage-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
            </svg>
          </div>
          <h3 class="font-bold text-text text-sm mb-1">One-on-One Lessons</h3>
          <p class="text-xs text-text/60">Online & children welcome</p>
        </div>
        <div class="text-center p-5 rounded-2xl bg-sage-50/50 border border-sage-100">
          <div class="w-14 h-14 mx-auto mb-3 rounded-2xl bg-sage-100 flex items-center justify-center">
            <svg class="w-7 h-7 text-sage-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z" />
            </svg>
          </div>
          <h3 class="font-bold text-text text-sm mb-1">Free Exam Prep</h3>
          <p class="text-xs text-text/60">Support until you pass</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Courses Section -->
  <section class="py-16 lg:py-24 bg-cream">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-text mb-3">{t(lang, 'courses.title')}</h2>
        <p class="text-text/60">{t(lang, 'courses.subtitle')}</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        {courses.map((course) => (
          <CourseCard
            title={course.data.title}
            description={course.data.description}
            certification={course.data.certification}
            price={course.data.price}
            sessions={course.data.sessions}
            totalHours={course.data.totalHours}
            slug={course.data.slug}
            image={course.data.image}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Articles Preview -->
  {articles.length > 0 && (
    <section class="py-16 lg:py-24 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-text mb-3">{t(lang, 'column.title')}</h2>
          <p class="text-text/60">{t(lang, 'column.subtitle')}</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
          {articles.map((article) => (
            <ArticleCard
              title={article.data.title}
              date={article.data.date}
              excerpt={article.data.excerpt}
              slug={article.data.slug}
              image={article.data.image}
            />
          ))}
        </div>
        <div class="text-center mt-8">
          <a href={`${base}/${lang}/articles/`} class="inline-flex items-center gap-2 text-sage-600 hover:text-sage-700 font-medium text-sm transition-colors">
            View all articles
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
            </svg>
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- Promotional Banners -->
  <section class="py-12 lg:py-16 bg-cream">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <a href={`${base}/${lang}/herbs/`} class="group block bg-white rounded-2xl p-6 border border-sage-100 shadow-sm hover:shadow-md transition-shadow text-center">
          <div class="w-14 h-14 mx-auto mb-4 rounded-2xl bg-sage-100 flex items-center justify-center group-hover:bg-sage-200 transition-colors">
            <svg class="w-7 h-7 text-sage-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
            </svg>
          </div>
          <h3 class="font-bold text-text mb-1">Herb Directory</h3>
          <p class="text-sm text-text/60">Browse medicinal herb profiles</p>
        </a>
        <a href="https://bg8s.theshop.jp/" target="_blank" rel="noopener noreferrer" class="group block bg-white rounded-2xl p-6 border border-sage-100 shadow-sm hover:shadow-md transition-shadow text-center">
          <div class="w-14 h-14 mx-auto mb-4 rounded-2xl bg-gold-100 flex items-center justify-center group-hover:bg-gold-200 transition-colors">
            <svg class="w-7 h-7 text-gold-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 1 0-7.5 0v4.5m11.356-1.993 1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 0 1-1.12-1.243l1.264-12A1.125 1.125 0 0 1 5.513 7.5h12.974c.576 0 1.059.435 1.119 1.007ZM8.625 10.5a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm7.5 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" />
            </svg>
          </div>
          <h3 class="font-bold text-text mb-1">Online Shop</h3>
          <p class="text-sm text-text/60">Browse herb products</p>
        </a>
        <a href={`${base}/${lang}/contact/`} class="group block bg-white rounded-2xl p-6 border border-sage-100 shadow-sm hover:shadow-md transition-shadow text-center">
          <div class="w-14 h-14 mx-auto mb-4 rounded-2xl bg-sage-100 flex items-center justify-center group-hover:bg-sage-200 transition-colors">
            <svg class="w-7 h-7 text-sage-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
            </svg>
          </div>
          <h3 class="font-bold text-text mb-1">Contact Us</h3>
          <p class="text-sm text-text/60">Free consultations available</p>
        </a>
      </div>
    </div>
  </section>

  <!-- Testimonials Carousel -->
  <section class="py-16 lg:py-24 bg-cream">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-text mb-3">{t(lang, 'voice.title')}</h2>
        <p class="text-text/60">{t(lang, 'voice.subtitle')}</p>
      </div>

      <div class="relative" id="testimonial-carousel">
        <div class="overflow-hidden">
          {testimonials.map((te, i) => (
            <div
              class:list={[
                'testimonial-slide transition-opacity duration-500',
                i === 0 ? 'opacity-100' : 'opacity-0 absolute inset-0',
              ]}
              data-tslide={i}
            >
              <div class="bg-white rounded-2xl p-6 lg:p-8 shadow-sm border border-sage-100 max-w-2xl mx-auto relative">
                <svg class="absolute top-4 right-5 w-10 h-10 text-sage-100 opacity-60" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609L9.978 5.151c-2.432.917-3.995 3.638-3.995 5.849H10v10H0z" />
                </svg>
                <div class="flex items-center gap-3 mb-4">
                  {iconMap[te.data.name] ? (
                    <img src={iconMap[te.data.name]} alt="" class="w-12 h-12 rounded-full shrink-0" />
                  ) : (
                    <div class="w-12 h-12 rounded-full bg-gradient-to-br from-sage-200 to-sage-300 flex items-center justify-center text-sage-700 font-bold text-sm shrink-0">
                      {te.data.name.charAt(0)}
                    </div>
                  )}
                  <div>
                    <p class="font-semibold text-text text-sm">
                      {te.data.name}
                      {te.data.age && <span class="text-text/40 font-normal text-xs ml-1">({te.data.age})</span>}
                    </p>
                    {te.data.occupation && <p class="text-xs text-text/45">{te.data.occupation}</p>}
                  </div>
                </div>
                <p class="text-sm text-text/75 leading-relaxed mb-4 relative z-10 line-clamp-4">{te.body}</p>
                <span class="inline-block text-xs font-medium text-gold-600 bg-gold-50 px-3 py-1.5 rounded-full border border-gold-200/50">{te.data.course}</span>
              </div>
            </div>
          ))}
        </div>

        <!-- Dots -->
        <div class="flex justify-center gap-2 mt-6">
          {testimonials.map((_, i) => (
            <button
              class:list={[
                'testimonial-dot w-2.5 h-2.5 rounded-full transition-all duration-300',
                i === 0 ? 'bg-sage-500 w-6' : 'bg-sage-300',
              ]}
              data-tdot={i}
              aria-label={`Testimonial ${i + 1}`}
            />
          ))}
        </div>
      </div>

      <div class="text-center mt-8">
        <a href={`${base}/${lang}/voice/`} class="inline-flex items-center gap-2 text-sage-600 hover:text-sage-700 font-medium text-sm transition-colors">
          View all testimonials
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
          </svg>
