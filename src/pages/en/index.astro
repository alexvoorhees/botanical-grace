---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CourseCard from '../../components/CourseCard.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { t } from '../../i18n/utils';

const lang = 'en';
const base = import.meta.env.BASE_URL;

const allCourses = await getCollection('courses');
const courses = allCourses
  .filter((c) => c.data.lang === lang)
  .sort((a, b) => a.data.order - b.data.order);

const allArticles = await getCollection('articles');
const articles = allArticles.filter((a) => a.data.lang === lang).slice(0, 3);
---

<BaseLayout>
  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-sage-50 via-cream to-sage-100 py-20 lg:py-32 overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-10 right-10 w-64 h-64 rounded-full bg-sage-300 blur-3xl"></div>
      <div class="absolute bottom-10 left-10 w-48 h-48 rounded-full bg-gold-300 blur-3xl"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-sage-600 font-medium tracking-widest uppercase text-sm mb-4">{t(lang, 'site.subtitle')}</p>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-text mb-6 tracking-tight">
        BOTANICAL<br class="sm:hidden" /> GRACE 8
      </h1>
      <p class="text-lg text-text/60 max-w-2xl mx-auto mb-10">
        A herb and aromatherapy certification school in Akasaka, Tokyo.
        Gain professional certifications with personalized, flexible instruction.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={`${base}${lang}/courses/`}
          class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-sage-600 text-white font-semibold rounded-xl hover:bg-sage-700 transition-colors text-lg"
        >
          {t(lang, 'hero.cta')}
        </a>
        <a
          href={`${base}${lang}/contact/`}
          class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-white text-sage-700 font-semibold rounded-xl border-2 border-sage-200 hover:border-sage-300 hover:bg-sage-50 transition-colors text-lg"
        >
          {t(lang, 'hero.contact')}
        </a>
      </div>
    </div>
  </section>

  <!-- Courses Section -->
  <section class="py-16 lg:py-24 bg-cream">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-text mb-3">{t(lang, 'courses.title')}</h2>
        <p class="text-text/60">{t(lang, 'courses.subtitle')}</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        {courses.map((course) => (
          <CourseCard
            title={course.data.title}
            description={course.data.description}
            certification={course.data.certification}
            price={course.data.price}
            sessions={course.data.sessions}
            totalHours={course.data.totalHours}
            slug={course.data.slug}
            image={course.data.image}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-16 lg:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center p-6">
          <div class="w-16 h-16 mx-auto mb-4 rounded-2xl bg-sage-50 flex items-center justify-center text-3xl">🎓</div>
          <h3 class="font-bold text-text mb-2">Recognized Certifications</h3>
          <p class="text-sm text-text/60">JAMHA and AEAJ certified programs with high pass rates</p>
        </div>
        <div class="text-center p-6">
          <div class="w-16 h-16 mx-auto mb-4 rounded-2xl bg-sage-50 flex items-center justify-center text-3xl">📅</div>
          <h3 class="font-bold text-text mb-2">Flexible Scheduling</h3>
          <p class="text-sm text-text/60">In-person or online via Zoom, 1-3 sessions per week</p>
        </div>
        <div class="text-center p-6">
          <div class="w-16 h-16 mx-auto mb-4 rounded-2xl bg-sage-50 flex items-center justify-center text-3xl">👩‍🏫</div>
          <h3 class="font-bold text-text mb-2">Personalized Instruction</h3>
          <p class="text-sm text-text/60">Small class sizes with dedicated, experienced teaching</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Articles Preview -->
  {articles.length > 0 && (
    <section class="py-16 lg:py-24 bg-cream">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-text mb-3">{t(lang, 'column.title')}</h2>
          <p class="text-text/60">{t(lang, 'column.subtitle')}</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
          {articles.map((article) => (
            <ArticleCard
              title={article.data.title}
              date={article.data.date}
              excerpt={article.data.excerpt}
              slug={article.data.slug}
              image={article.data.image}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="py-16 lg:py-24 bg-sage-700 text-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold mb-4">Start Your Herbal Journey</h2>
      <p class="text-sage-200 mb-8 text-lg">Contact us for a free consultation or to learn more about our certification programs.</p>
      <a
        href={`${base}${lang}/contact/`}
        class="inline-flex items-center gap-2 px-8 py-4 bg-gold-400 text-sage-900 font-semibold rounded-xl hover:bg-gold-300 transition-colors text-lg"
      >
        {t(lang, 'nav.contact')}
      </a>
    </div>
  </section>
</BaseLayout>
