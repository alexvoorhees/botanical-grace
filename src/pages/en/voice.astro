---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TestimonialCard from '../../components/TestimonialCard.astro';
import { getCollection, render } from 'astro:content';
import { t } from '../../i18n/utils';

const lang = 'en';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const allTestimonials = await getCollection('testimonials');
const testimonials = allTestimonials.filter((te) => te.data.lang === lang);

const renderedTestimonials = await Promise.all(
  testimonials.map(async (te) => {
    const { Content } = await render(te);
    return { data: te.data, Content, body: te.body };
  })
);

// Sort: longer testimonials first for visual interest
const sorted = renderedTestimonials.sort((a, b) => b.body.length - a.body.length);

// Map names to illustrated avatar icons from original site
const iconMap: Record<string, string> = {
  'T.N.': `${base}/images/voice/icons/voice_icon1.png`,
  'K.T.': `${base}/images/voice/icons/voice_icon2.png`,
  'M.Y.': `${base}/images/voice/icons/voice_icon3.png`,
  'Y.S.': `${base}/images/voice/icons/voice_icon4.png`,
  'H.M.': `${base}/images/voice/icons/voice_icon5.png`,
  'M.K.': `${base}/images/voice/icons/voice_icon6.png`,
  'A.K.': `${base}/images/voice/icons/voice_icon7.png`,
  'M.T.': `${base}/images/voice/icons/voice_icon8.png`,
  'M.S.': `${base}/images/voice/icons/voice_icon1.png`,
};
---

<BaseLayout title={t(lang, 'voice.title')}>
  <!-- Compact hero -->
  <section class="bg-gradient-to-br from-sage-50 via-cream to-gold-50 py-10 lg:py-14">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-3xl lg:text-4xl font-bold text-text mb-2">{t(lang, 'voice.title')}</h1>
      <p class="text-text/55">{t(lang, 'voice.subtitle')}</p>
    </div>
  </section>

  <!-- Testimonials grid -->
  <section class="py-10 lg:py-16">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="columns-1 md:columns-2 gap-6 space-y-6">
        {sorted.map(({ data, body }) => (
          <div class="break-inside-avoid">
            <TestimonialCard
              name={data.name}
              age={data.age}
              occupation={data.occupation}
              course={data.course}
              content={body}
              icon={iconMap[data.name]}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-12 bg-sage-50 border-t border-sage-100">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-xl font-bold text-text mb-3">Ready to Start Your Journey?</h2>
      <p class="text-sm text-text/55 mb-6">Join our community of passionate herbal therapy students.</p>
      <a
        href={`${base}/${lang}/contact/`}
        class="inline-flex items-center gap-2 px-6 py-3 bg-sage-600 text-white font-semibold rounded-xl hover:bg-sage-700 transition-colors text-sm"
      >
        Contact Us
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>
  </section>
</BaseLayout>
