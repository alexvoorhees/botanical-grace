---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { t } from '../../../i18n/utils';
import { render } from 'astro:content';

const lang = 'ja';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

export async function getStaticPaths() {
  const allCourses = await getCollection('courses');
  return allCourses
    .filter((c) => c.data.lang === 'ja')
    .map((course) => ({
      params: { slug: course.data.slug },
      props: { course },
    }));
}

const { course } = Astro.props;
const { Content } = await render(course);
const d = course.data;
---

<BaseLayout title={d.title}>
  <!-- Hero Banner -->
  <section class="relative overflow-hidden bg-sage-800">
    {d.heroImage && (
      <img
        src={d.heroImage}
        alt=""
        class="absolute inset-0 w-full h-full object-cover opacity-30"
      />
    )}
    <div class="absolute inset-0 bg-gradient-to-b from-sage-900/40 to-sage-900/80"></div>
    <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-24">
      <!-- Breadcrumb -->
      <nav class="mb-6 text-sm text-white/50">
        <a href={`${base}/${lang}/`} class="hover:text-white/80">{t(lang, 'nav.home')}</a>
        <span class="mx-2">/</span>
        <a href={`${base}/${lang}/courses/`} class="hover:text-white/80">{t(lang, 'nav.courses')}</a>
        <span class="mx-2">/</span>
        <span class="text-white/70">{d.title}</span>
      </nav>

      <span class="inline-block text-sm font-semibold text-sage-200 bg-white/15 backdrop-blur-sm px-4 py-1.5 rounded-full mb-4 border border-white/20">
        {d.certification} 認定
      </span>
      <h1 class="text-3xl lg:text-4xl font-bold text-white mb-3 text-balance">{d.title}</h1>
      {d.subtitle && <p class="text-lg text-white/80 max-w-2xl leading-relaxed">{d.subtitle}</p>}
    </div>
  </section>

  <!-- Quick Info Cards -->
  <section class="relative -mt-8 z-10">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-white rounded-2xl shadow-lg border border-sage-100 p-6 lg:p-8">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          <div class="text-center">
            <div class="w-12 h-12 mx-auto mb-2 rounded-xl bg-sage-50 flex items-center justify-center">
              <svg class="w-6 h-6 text-sage-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
              </svg>
            </div>
            <p class="text-xs text-text/50 mb-0.5">受講料</p>
            <p class="text-lg font-bold text-sage-700">¥{d.price.toLocaleString()}</p>
          </div>
          <div class="text-center">
            <div class="w-12 h-12 mx-auto mb-2 rounded-xl bg-sage-50 flex items-center justify-center">
              <svg class="w-6 h-6 text-sage-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
              </svg>
            </div>
            <p class="text-xs text-text/50 mb-0.5">回数</p>
            <p class="text-lg font-bold text-sage-700">{d.sessions}<span class="text-sm font-normal">回</span></p>
          </div>
          <div class="text-center">
            <div class="w-12 h-12 mx-auto mb-2 rounded-xl bg-sage-50 flex items-center justify-center">
              <svg class="w-6 h-6 text-sage-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
              </svg>
            </div>
            <p class="text-xs text-text/50 mb-0.5">総時間</p>
            <p class="text-lg font-bold text-sage-700">{d.totalHours}<span class="text-sm font-normal">時間</span></p>
          </div>
          {d.textbookPrice ? (
            <div class="text-center">
              <div class="w-12 h-12 mx-auto mb-2 rounded-xl bg-sage-50 flex items-center justify-center">
                <svg class="w-6 h-6 text-sage-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
                </svg>
              </div>
              <p class="text-xs text-text/50 mb-0.5">テキスト代</p>
              <p class="text-lg font-bold text-sage-700">¥{d.textbookPrice.toLocaleString()}</p>
            </div>
          ) : (
            <div class="text-center">
              <div class="w-12 h-12 mx-auto mb-2 rounded-xl bg-sage-50 flex items-center justify-center">
                <svg class="w-6 h-6 text-sage-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z" />
                </svg>
              </div>
              <p class="text-xs text-text/50 mb-0.5">認定</p>
              <p class="text-lg font-bold text-sage-700">{d.certification}</p>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- Course Content -->
  <section class="py-12 lg:py-20">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10 lg:gap-12">
        <!-- Main Content -->
        <div class="lg:col-span-2">
          <div class="course-content prose prose-sage max-w-none
            prose-headings:text-text prose-headings:font-bold
            prose-h2:text-xl prose-h2:mt-10 prose-h2:mb-4 prose-h2:pb-3 prose-h2:border-b prose-h2:border-sage-200
            prose-h3:text-base prose-h3:mt-6 prose-h3:mb-3 prose-h3:text-sage-700
            prose-p:text-text/70 prose-p:leading-relaxed
            prose-li:text-text/70
            prose-strong:text-text
          ">
            <Content />
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="lg:col-span-1">
          <div class="sticky top-8 space-y-6">
            <!-- Course Image -->
            {d.heroImage && (
              <div class="rounded-2xl overflow-hidden shadow-sm border border-sage-100">
                <img src={d.heroImage} alt={d.title} class="w-full aspect-[4/3] object-cover" />
              </div>
            )}

            <!-- Quick Apply -->
            <div class="bg-sage-50 rounded-2xl p-6 border border-sage-100">
              <h3 class="font-bold text-text mb-3 text-sm">受講のお申し込み</h3>
              <p class="text-xs text-text/60 mb-4 leading-relaxed">無料説明会も開催中です。お気軽にお問い合わせください。</p>
              <a
                href={`${base}/${lang}/contact/`}
                class="block w-full text-center px-6 py-3 bg-gold-400 text-sage-900 font-semibold rounded-xl hover:bg-gold-300 transition-colors text-sm"
              >
                {t(lang, 'nav.contact')}
              </a>
              <a
                href="tel:070-1581-0168"
                class="block w-full text-center px-6 py-3 mt-3 bg-white text-sage-700 font-semibold rounded-xl border border-sage-200 hover:bg-sage-50 transition-colors text-sm"
              >
                TEL: 070-1581-0168
              </a>
            </div>

            <!-- Features -->
            <div class="bg-white rounded-2xl p-6 border border-sage-100">
              <h3 class="font-bold text-text mb-3 text-sm">教室の特徴</h3>
              <ul class="space-y-3">
                <li class="flex items-start gap-2.5">
                  <svg class="w-5 h-5 text-sage-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                  </svg>
                  <span class="text-xs text-text/70">JAMHA・AEAJ認定教室</span>
                </li>
                <li class="flex items-start gap-2.5">
                  <svg class="w-5 h-5 text-sage-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                  </svg>
                  <span class="text-xs text-text/70">マンツーマン・オンライン対応</span>
                </li>
                <li class="flex items-start gap-2.5">
                  <svg class="w-5 h-5 text-sage-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                  </svg>
                  <span class="text-xs text-text/70">柔軟なスケジュール調整</span>
                </li>
                <li class="flex items-start gap-2.5">
                  <svg class="w-5 h-5 text-sage-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                  </svg>
                  <span class="text-xs text-text/70">無料試験対策付き</span>
                </li>
                <li class="flex items-start gap-2.5">
                  <svg class="w-5 h-5 text-sage-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                  </svg>
                  <span class="text-xs text-text/70">お子様連れでも受講可能</span>
                </li>
              </ul>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 lg:py-20 bg-sage-700 text-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl lg:text-3xl font-bold mb-4 text-balance">無料説明会を実施中</h2>
      <p class="text-sage-200 mb-8 leading-relaxed">講座の内容について詳しくご説明いたします。お気軽にお問い合わせください。</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={`${base}/${lang}/contact/`}
          class="inline-flex items-center gap-2 px-8 py-4 bg-gold-400 text-sage-900 font-semibold rounded-xl hover:bg-gold-300 transition-colors text-lg"
        >
          {t(lang, 'nav.contact')}
        </a>
        <a
          href="tel:070-1581-0168"
          class="inline-flex items-center gap-2 px-8 py-4 bg-white/15 text-white font-semibold rounded-xl border-2 border-white/30 hover:bg-white/25 transition-colors text-lg"
        >
          TEL: 070-1581-0168
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
