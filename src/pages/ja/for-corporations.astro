---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from '../../i18n/utils';

const lang = 'ja';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const useCases = [
  t(lang, 'corporate.usecase1'),
  t(lang, 'corporate.usecase2'),
  t(lang, 'corporate.usecase3'),
  t(lang, 'corporate.usecase4'),
  t(lang, 'corporate.usecase5'),
];

const courseRows = [
  { label: t(lang, 'corporate.course.overview.label'), value: t(lang, 'corporate.course.overview.value') },
  { label: t(lang, 'corporate.course.schedule.label'), value: t(lang, 'corporate.course.schedule.value') },
  { label: t(lang, 'corporate.course.duration.label'), value: t(lang, 'corporate.course.duration.value') },
  { label: t(lang, 'corporate.course.textbook.label'), value: t(lang, 'corporate.course.textbook.value') },
  { label: t(lang, 'corporate.course.price.label'), value: null, isPrice: true },
];
---

<BaseLayout title={t(lang, 'corporate.title')}>
  <!-- Hero / Title -->
  <section class="py-16 lg:py-24">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h1 class="text-3xl lg:text-4xl font-bold text-text mb-3">{t(lang, 'corporate.title')}</h1>
        <p class="text-text/60">{t(lang, 'corporate.subtitle')}</p>
      </div>

      <!-- Proposal Card with Image -->
      <div class="bg-white rounded-2xl shadow-sm border border-sage-100 overflow-hidden">
        <div class="grid grid-cols-1 lg:grid-cols-2">
          <div class="p-6 lg:p-10">
            <h2 class="text-xl lg:text-2xl font-bold text-text mb-4">{t(lang, 'corporate.proposal.heading')}</h2>
            <p class="text-text/70 leading-relaxed mb-8">{t(lang, 'corporate.proposal.description')}</p>

            <ul class="space-y-3">
              {useCases.map((uc) => (
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-sage-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                  </svg>
                  <span class="text-text/70">{uc}</span>
                </li>
              ))}
            </ul>
          </div>
          <div class="hidden lg:block">
            <img
              src={`${base}/images/courses/for_corporations_hero.png`}
              alt={t(lang, 'corporate.title')}
              class="w-full h-full object-cover"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- About JAMHA -->
  <section class="py-16 lg:py-20 bg-sage-200">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-xl lg:text-2xl font-bold text-text mb-4">{t(lang, 'corporate.jamha.heading')}</h2>
      <p class="text-text/70 leading-relaxed mb-8 max-w-2xl mx-auto">{t(lang, 'corporate.jamha.description')}</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="https://www.medicalherb.or.jp/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-6 py-3 border-2 border-sage-400 text-sage-700 font-semibold rounded-xl hover:bg-sage-100 transition-colors"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
          </svg>
          {t(lang, 'corporate.jamha.link')}
        </a>
        <a
          href={`${base}/${lang}/courses/therapist/`}
          class="inline-flex items-center gap-2 px-6 py-3 bg-sage-500 text-white font-semibold rounded-xl hover:bg-sage-600 transition-colors"
        >
          {t(lang, 'corporate.course.link')}
        </a>
      </div>
    </div>
  </section>

  <!-- Course Details -->
  <section class="py-16 lg:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-xl lg:text-2xl font-bold text-text mb-8 text-center">{t(lang, 'corporate.course.heading')}</h2>
      <div class="bg-white rounded-2xl shadow-sm border border-sage-100 overflow-hidden divide-y divide-sage-100">
        {courseRows.map((row) => (
          <div class="grid grid-cols-1 sm:grid-cols-[200px_1fr]">
            <div class="bg-sage-50 px-6 py-4 font-semibold text-text text-sm">{row.label}</div>
            <div class="px-6 py-4 text-text/70">
              {row.isPrice ? (
                <span>
                  {t(lang, 'corporate.course.price.value')}
                  <strong class="text-sage-700 text-lg">{t(lang, 'corporate.course.price.highlight')}</strong>
                </span>
              ) : row.value ? (
                <span>{row.value}</span>
              ) : (
                <span class="text-text/40">—</span>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact CTA -->
  <section class="py-16 lg:py-20 bg-sage-700 text-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl lg:text-3xl font-bold mb-4">{t(lang, 'corporate.contact.heading')}</h2>
      <a href="tel:070-1581-0168" class="inline-block text-2xl font-bold text-gold-300 hover:text-gold-200 transition-colors mb-2">
        {t(lang, 'footer.phone')}
      </a>
      <p class="text-sage-200 mb-4 text-sm">{t(lang, 'corporate.contact.hours')}</p>
      <p class="text-sage-200 mb-8 leading-relaxed max-w-xl mx-auto">{t(lang, 'corporate.contact.note')}</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={`${base}/${lang}/contact/`}
          class="inline-flex items-center gap-2 px-8 py-4 bg-gold-400 text-sage-900 font-semibold rounded-xl hover:bg-gold-300 transition-colors text-lg"
        >
          {t(lang, 'corporate.contact.form')}
        </a>
        <a
          href="tel:070-1581-0168"
          class="inline-flex items-center gap-2 px-8 py-4 bg-white/15 text-white font-semibold rounded-xl border-2 border-white/30 hover:bg-white/25 transition-colors text-lg"
        >
          TEL: {t(lang, 'footer.phone')}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
