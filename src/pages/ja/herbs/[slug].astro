---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { t } from '../../../i18n/utils';

const lang = 'ja';
const base = import.meta.env.BASE_URL;

export async function getStaticPaths() {
  const allHerbs = await getCollection('herbs');
  return allHerbs
    .filter((h) => h.data.lang === 'ja')
    .map((herb) => ({
      params: { slug: herb.data.slug },
      props: { herb },
    }));
}

const { herb } = Astro.props;
const { Content } = await render(herb);
---

<BaseLayout title={herb.data.title}>
  <article class="py-16 lg:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="mb-8 text-sm text-text/50">
        <a href={`${base}${lang}/`} class="hover:text-sage-600">{t(lang, 'nav.home')}</a>
        <span class="mx-2">/</span>
        <a href={`${base}${lang}/herbs/`} class="hover:text-sage-600">{t(lang, 'nav.herbs')}</a>
        <span class="mx-2">/</span>
        <span class="text-text/70">{herb.data.title}</span>
      </nav>

      <div class="mb-8">
        <h1 class="text-3xl lg:text-4xl font-bold text-text mb-2">{herb.data.title}</h1>
        <p class="text-text/50">
          {herb.data.nameEn} / <span class="italic">{herb.data.scientificName}</span>
        </p>
      </div>

      <div class="flex flex-wrap gap-2 mb-8">
        {herb.data.actions.map((action) => (
          <span class="text-sm bg-sage-50 text-sage-600 px-3 py-1 rounded-full">{action}</span>
        ))}
      </div>

      <div class="prose prose-sage max-w-none prose-headings:text-text prose-p:text-text/70 prose-p:leading-relaxed">
        <Content />
      </div>

      <div class="mt-10">
        <a href={`${base}${lang}/herbs/`} class="text-sage-500 hover:text-sage-600 text-sm font-medium">
          ← {t(lang, 'common.back')}
        </a>
      </div>
    </div>
  </article>
</BaseLayout>
