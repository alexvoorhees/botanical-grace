---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { t } from '../../../i18n/utils';

const lang = 'ja';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

export async function getStaticPaths() {
  const allHerbs = await getCollection('herbs');
  return allHerbs
    .filter((h) => h.data.lang === 'ja')
    .map((herb) => ({
      params: { slug: herb.data.slug },
      props: { herb },
    }));
}

const { herb } = Astro.props;
const { Content } = await render(herb);
const hasImage = !!herb.data.image;
---

<BaseLayout title={herb.data.title}>
  <!-- Hero section with botanical illustration -->
  <div class="bg-gradient-to-b from-sage-50 to-cream">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-8 pb-4">
      <nav class="text-sm text-text/50 mb-6">
        <a href={`${base}/${lang}/`} class="hover:text-sage-600 transition-colors">{t(lang, 'nav.home')}</a>
        <span class="mx-2 text-text/30">/</span>
        <a href={`${base}/${lang}/herbs/`} class="hover:text-sage-600 transition-colors">{t(lang, 'nav.herbs')}</a>
        <span class="mx-2 text-text/30">/</span>
        <span class="text-text/70">{herb.data.title}</span>
      </nav>
    </div>

    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pb-12">
      <div class={`flex flex-col ${hasImage ? 'lg:flex-row' : ''} gap-8 lg:gap-12 items-center`}>
        {/* Botanical illustration */}
        {hasImage && (
          <div class="w-full lg:w-2/5 shrink-0">
            <div class="relative">
              {/* Decorative frame */}
              <div class="absolute -inset-3 bg-white/60 rounded-3xl border border-sage-200/40 -rotate-2"></div>
              <div class="relative bg-white rounded-2xl p-4 shadow-sm border border-sage-100 rotate-0">
                <img
                  src={herb.data.image}
                  alt={herb.data.title}
                  class="w-full rounded-xl"
                />
              </div>
              {/* Scientific name label */}
              <div class="absolute -bottom-3 left-1/2 -translate-x-1/2 bg-white px-4 py-1.5 rounded-full shadow-sm border border-sage-100 text-xs italic text-text/50 whitespace-nowrap">
                {herb.data.scientificName}
              </div>
            </div>
          </div>
        )}

        {/* Title and meta */}
        <div class={`flex-1 ${hasImage ? 'lg:py-4' : 'text-center max-w-2xl mx-auto'}`}>
          <h1 class="text-3xl lg:text-4xl font-bold text-text mb-2 leading-tight">{herb.data.title}</h1>
          <p class="text-lg text-text/45 mb-1">
            {herb.data.nameEn}
          </p>
          {!hasImage && (
            <p class="text-sm italic text-text/40 mb-4">{herb.data.scientificName}</p>
          )}

          {/* Action badges */}
          <div class={`flex flex-wrap gap-2 ${hasImage ? 'mt-6' : 'mt-4 justify-center'}`}>
            {herb.data.actions.map((action) => (
              <span class="inline-flex items-center gap-1.5 text-sm bg-white text-sage-700 pl-2.5 pr-3.5 py-1.5 rounded-full border border-sage-200/60 shadow-sm">
                <svg class="w-3.5 h-3.5 text-sage-400" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd" />
                </svg>
                {action}
              </span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Content body -->
  <article class="py-12 lg:py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="prose prose-sage max-w-none prose-headings:text-text prose-headings:font-bold prose-h2:text-xl prose-h2:mt-10 prose-h2:mb-4 prose-h2:pb-2 prose-h2:border-b prose-h2:border-sage-100 prose-p:text-text/70 prose-p:leading-relaxed prose-li:text-text/70 prose-strong:text-text/85">
        <Content />
      </div>

      <!-- Back link -->
      <div class="mt-12 pt-8 border-t border-sage-100">
        <a href={`${base}/${lang}/herbs/`} class="inline-flex items-center gap-2 text-sage-500 hover:text-sage-700 text-sm font-medium transition-colors group">
          <svg class="w-4 h-4 group-hover:-translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
          </svg>
          {t(lang, 'common.back')}
        </a>
      </div>
    </div>
  </article>
</BaseLayout>
