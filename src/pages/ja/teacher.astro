---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { t } from '../../i18n/utils';

const lang = 'ja';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const allTeacher = await getCollection('teacher');
const teacherEntry = allTeacher.find((te) => te.data.lang === lang);

let Content: any = null;
let data: any = null;
if (teacherEntry) {
  const rendered = await render(teacherEntry);
  Content = rendered.Content;
  data = teacherEntry.data;
}

const schoolCerts = [
  { image: `${base}/images/teacher/certs/teacher_img1.png`, name: 'JAMHA メディカルハーブ検定\n認定教室', org: 'JAMHA' },
  { image: `${base}/images/teacher/certs/teacher_img2.png`, name: 'JAMHA ハーバルセラピスト\n認定教室', org: 'JAMHA' },
  { image: `${base}/images/teacher/certs/teacher_img3.png`, name: 'AEAJ アロマテラピーアドバイザー\n認定教室', org: 'AEAJ' },
];

const qualificationCerts = [
  { image: `${base}/images/teacher/certs/teacher_img4.png`, name: 'ハーバルプラクティショナー', org: 'JAMHA' },
  { image: `${base}/images/teacher/certs/teacher_img5.png`, name: 'ハーバルセラピスト', org: 'JAMHA' },
  { image: `${base}/images/teacher/certs/teacher_img6.png`, name: 'メディカルハーブコーディネーター', org: 'JAMHA' },
  { image: `${base}/images/teacher/certs/teacher_img7.png`, name: 'ハーブ＆ライフコーディネーター', org: 'JAMHA' },
  { image: `${base}/images/teacher/certs/teacher_img8.png`, name: 'アロマテラピーインストラクター', org: 'AEAJ' },
  { image: `${base}/images/teacher/certs/teacher_img9.png`, name: 'アーユルヴェーダアドバイザー', org: 'JAPA' },
  { image: `${base}/images/teacher/certs/teacher_img10.png`, name: '健康経営エキスパートアドバイザー', org: '' },
  { image: `${base}/images/teacher/certs/teacher_img11.png`, name: 'レイキマスター', org: '' },
  { image: `${base}/images/teacher/certs/teacher_img12.png`, name: '調理師免許', org: '東京都' },
];

const additionalQualifications = [
  'JAMHA認定シニアハーバルセラピスト',
  'AEAJ認定ナチュラルビューティスタイリスト',
  'スパイス＆ハーブ検定',
  '野菜ソムリエ',
  '食生活アドバイザー',
  '漢方養生指導士',
  'ハーブ薬膳フードデザイナー',
];
---

<BaseLayout title={t(lang, 'teacher.title')}>
  {data && (
    <>
      <!-- Hero / Greeting -->
      <section class="py-16 lg:py-24 bg-white">
        <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="text-center mb-12">
            <h1 class="text-3xl lg:text-4xl font-bold text-text mb-3">{t(lang, 'teacher.title')}</h1>
            <p class="text-text/60">BOTANICAL GRACE 8 について</p>
          </div>

          <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
            <!-- Greeting Text -->
            <div class="prose prose-sage max-w-none prose-headings:text-text prose-p:text-text/70 prose-p:leading-relaxed prose-h2:text-2xl prose-h2:border-b prose-h2:border-sage-200 prose-h2:pb-2">
              {Content && <Content />}
            </div>

            <!-- Photo -->
            <div class="flex flex-col items-center gap-4">
              <div class="relative">
                {data.image ? (
                  <img
                    src={data.image}
                    alt={data.name}
                    class="w-64 h-64 lg:w-72 lg:h-72 object-cover rounded-full shadow-lg border-4 border-sage-100"
                  />
                ) : (
                  <div class="w-64 h-64 lg:w-72 lg:h-72 rounded-full bg-sage-100 flex items-center justify-center">
                    <svg class="w-24 h-24 text-sage-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
                    </svg>
                  </div>
                )}
              </div>
              <div class="text-center">
                <p class="text-xl font-bold text-text">{data.name}</p>
                <p class="text-sm text-text/60">{data.title}</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- School Certifications -->
      <section class="py-16 lg:py-20 bg-cream">
        <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="text-center mb-10">
            <h2 class="text-2xl lg:text-3xl font-bold text-text mb-3 text-balance">認定教室</h2>
            <p class="text-text/60 leading-relaxed">公式認定を受けた信頼ある教育施設です</p>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            {schoolCerts.map((cert) => (
              <div class="bg-white rounded-2xl p-5 border border-sage-100 shadow-sm text-center">
                <img
                  src={cert.image}
                  alt={cert.name}
                  class="w-full aspect-[3/4] object-contain rounded-lg mb-4"
                  loading="lazy"
                />
                <span class="inline-block text-xs font-semibold text-sage-600 bg-sage-50 px-3 py-1 rounded-full mb-2">{cert.org}</span>
                <p class="font-bold text-text text-sm leading-snug whitespace-pre-line">{cert.name}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Qualification Certificates -->
      <section class="py-16 lg:py-20 bg-white">
        <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="text-center mb-10">
            <h2 class="text-2xl lg:text-3xl font-bold text-text mb-3 text-balance">保有資格</h2>
            <p class="text-text/60 leading-relaxed">講師の専門資格・認定証</p>
          </div>
          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 lg:gap-6">
            {qualificationCerts.map((cert) => (
              <div class="bg-sage-50/50 rounded-xl p-3 border border-sage-100 text-center group hover:shadow-md transition-shadow">
                <img
                  src={cert.image}
                  alt={cert.name}
                  class="w-full aspect-[3/4] object-contain rounded-lg mb-3"
                  loading="lazy"
                />
                {cert.org && (
                  <span class="inline-block text-[10px] font-semibold text-sage-600 bg-sage-100 px-2 py-0.5 rounded-full mb-1">{cert.org}</span>
                )}
                <p class="font-medium text-text text-xs leading-snug">{cert.name}</p>
              </div>
            ))}
          </div>

          <!-- Additional qualifications without certificate images -->
          <div class="mt-10 max-w-2xl mx-auto">
            <h3 class="text-sm font-bold text-text/70 mb-4 text-center">その他の資格</h3>
            <div class="flex flex-wrap justify-center gap-2">
              {additionalQualifications.map((q) => (
                <span class="inline-flex items-center gap-1.5 text-xs bg-sage-50 text-sage-700 px-3 py-2 rounded-lg border border-sage-100">
                  <svg class="w-3.5 h-3.5 text-sage-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                  </svg>
                  {q}
                </span>
              ))}
            </div>
          </div>
        </div>
      </section>

      <!-- CTA -->
      <section class="py-16 lg:py-20 bg-sage-700 text-white">
        <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
          <h2 class="text-2xl lg:text-3xl font-bold mb-4 text-balance">無料説明会を実施中</h2>
          <p class="text-sage-200 mb-8 text-lg leading-relaxed">講座の内容について詳しくご説明いたします。お気軽にお問い合わせください。</p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a
              href={`${base}/${lang}/contact/`}
              class="inline-flex items-center gap-2 px-8 py-4 bg-gold-400 text-sage-900 font-semibold rounded-xl hover:bg-gold-300 transition-colors text-lg"
            >
              {t(lang, 'nav.contact')}
            </a>
            <a
              href="tel:070-1581-0168"
              class="inline-flex items-center gap-2 px-8 py-4 bg-white/15 text-white font-semibold rounded-xl border-2 border-white/30 hover:bg-white/25 transition-colors text-lg"
            >
              TEL: 070-1581-0168
            </a>
          </div>
        </div>
      </section>
    </>
  )}
</BaseLayout>
